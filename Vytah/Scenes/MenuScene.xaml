<UserControl x:Class="Vytah.Scenes.MenuScene"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="1672" Height="941">
    <Grid Width="1672" Height="941">
        <Image x:Name="BgImage"
               Source="pack://application:,,,/Assets/Backgrounds/titulniscena_vytah.png"
               Stretch="UniformToFill"/>

        <!-- NOVÁ HRA -->
        <Border Width="376" Height="79"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="139,533,0,0"
                Background="Transparent"
                Cursor="Hand"
                MouseLeftButtonDown="BtnNovaHra_Click">
        </Border>

        <!-- UKONČIT -->
        <Border Width="376" Height="80"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="139,637,0,0"
                Background="Transparent"
                Cursor="Hand"
                MouseLeftButtonDown="BtnUkoncit_Click">
        </Border>
    </Grid>
</UserControl>