<UserControl x:Class="Vytah.Scenes.Scene4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Canvas Width="1672" Height="941">
        <Image x:Name="BgImage"
               Source="pack://application:,,,/Assets/Backgrounds/scena4_vytah.png"
               Width="1672" Height="941"
               Stretch="UniformToFill"
               Canvas.Left="0" Canvas.Top="0"/>

        <Rectangle Width="1672" Height="941"
                   Fill="#33000000"
                   IsHitTestVisible="False"
                   Canvas.Left="0" Canvas.Top="0"/>

        <!-- SCHRÁNKY - vlevo -->
        <Border x:Name="HitSchranky"
                Width="365" Height="370"
                Canvas.Left="10" Canvas.Top="300"
                Background="Transparent" Cursor="Hand"
                ToolTip="Schránky"
                MouseLeftButtonDown="HitSchranky_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <!-- NOUZOVÁ LAMPIČKA - vlevo nahoře -->
        <Border x:Name="HitAlarm"
                Width="60" Height="65"
                Canvas.Left="420" Canvas.Top="195"
                Background="Transparent" Cursor="Hand"
                ToolTip="Nouzová lampička"
                MouseLeftButtonDown="HitAlarm_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <!-- ROZVODNÁ SKŘÍŇ - vpravo vedle výtahu -->
        <Border x:Name="HitRozvod"
                Width="257" Height="380"
                Canvas.Left="1405" Canvas.Top="206"
                Background="Transparent" Cursor="Hand"
                ToolTip="Rozvodná skříň"
                MouseLeftButtonDown="HitRozvod_Click" HorizontalAlignment="Left" VerticalAlignment="Center"/>

        <!-- PUZZLE - přes celý Canvas -->
        <Border x:Name="FusePuzzle"
                Width="1672" Height="941"
                Canvas.Left="0" Canvas.Top="0"
                Visibility="Collapsed"
                Background="#EE000000">
            <Border Background="#0A0A0A" BorderBrush="#2A2A2A"
                    BorderThickness="1" CornerRadius="6"
                    Padding="36" Width="400"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="ROZVODNÁ SKŘÍŇ" Foreground="#444444"
                               FontFamily="Courier New" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Klikej na slot pro přepnutí barvy pojistky."
                               Foreground="#555555" FontFamily="Courier New"
                               FontSize="11" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="8,0">
                            <TextBlock Text="SLOT 1" Foreground="#333333"
                                       FontFamily="Courier New" FontSize="9"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Button x:Name="Slot1" Content="[ — ]"
                                    Width="90" Height="54" Tag="0"
                                    FontFamily="Courier New" FontSize="15"
                                    Click="SlotButton_Click"/>
                        </StackPanel>
                        <StackPanel Margin="8,0">
                            <TextBlock Text="SLOT 2" Foreground="#333333"
                                       FontFamily="Courier New" FontSize="9"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Button x:Name="Slot2" Content="[ — ]"
                                    Width="90" Height="54" Tag="1"
                                    FontFamily="Courier New" FontSize="15"
                                    Click="SlotButton_Click"/>
                        </StackPanel>
                        <StackPanel Margin="8,0">
                            <TextBlock Text="SLOT 3" Foreground="#333333"
                                       FontFamily="Courier New" FontSize="9"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Button x:Name="Slot3" Content="[ — ]"
                                    Width="90" Height="54" Tag="2"
                                    FontFamily="Courier New" FontSize="15"
                                    Click="SlotButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="PuzzleStatus" Text=""
                               Foreground="#AA3333" FontFamily="Courier New"
                               FontSize="11" HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                    <Button Content="[ zapojit ]" Margin="0,16,0,4"
                            Click="OdeslitPuzzle_Click"
                            Padding="16,8" FontFamily="Courier New"/>
                    <Button Content="zrušit" Margin="0,6,0,0"
                            Click="CancelPuzzle_Click"
                            Background="Transparent" Foreground="#444444"
                            BorderThickness="0" FontFamily="Courier New"/>
                </StackPanel>
            </Border>
        </Border>
    </Canvas>
</UserControl>