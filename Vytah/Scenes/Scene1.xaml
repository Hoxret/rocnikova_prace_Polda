<UserControl x:Class="Vytah.Scenes.Scene1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Canvas Width="1672" Height="941">
        <Image x:Name="BgImage"
               Source="pack://application:,,,/Assets/Backgrounds/scena1_vytah.png"
               Width="1672" Height="941"
               Stretch="UniformToFill"
               Canvas.Left="0" Canvas.Top="0"/>

        <!-- BUTTON NA STAROU PANÍ -->
        <Button x:Name="BtnOldLady"
                Width="331" Height="622"
                Canvas.Left="268" Canvas.Top="309"
                Click="BtnOldLady_Click"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                ToolTip="Promluvit se starou paní" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- BUTTON NA MUŽE V OBLEKU -->
        <Button x:Name="BtnMan"
                Width="304" Height="692"
                Canvas.Left="1045" Canvas.Top="239"
                Click="BtnMan_Click"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                IsEnabled="False"
                ToolTip="Promluvit s mužem v obleku" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- BUTTON NA OVLÁDACÍ PANEL VÝTAHU -->
        <Button x:Name="BtnLiftPanel"
                Width="153" Height="686"
                Canvas.Left="1384" Canvas.Top="100"
                Click="BtnLiftPanel_Click"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                IsEnabled="False"
                ToolTip="Ovládat výtah" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    </Canvas>
</UserControl>