<UserControl x:Class="Vytah.Scenes.Scene2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Canvas Width="1672" Height="941">
        <Image x:Name="BgImage"
               Source="pack://application:,,,/Assets/Backgrounds/scena2_vytah.png"
               Width="1672" Height="941"
               Stretch="UniformToFill"
               Canvas.Left="0" Canvas.Top="0"/>

        <!-- SCHRÁNKY - vlevo -->
        <Border x:Name="HitSchranky"
                Width="386" Height="270"
                Canvas.Left="109" Canvas.Top="290"
                Background="Transparent" Cursor="Hand"
                ToolTip="Prozkoumat schránky"
                MouseLeftButtonDown="HitSchranky_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <!-- KOLO - vlevo dole -->
        <Border x:Name="HitKolo"
                Width="375" Height="260"
                Canvas.Left="155" Canvas.Top="600"
                Background="Transparent" Cursor="Hand"
                ToolTip="Dětské kolo"
                MouseLeftButtonDown="HitKolo_Click" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- SVĚTLO - nahoře uprostřed -->
        <Border x:Name="HitSvetlo"
                Width="80" Height="80"
                Canvas.Left="796" Canvas.Top="10"
                Background="Transparent" Cursor="Hand"
                ToolTip="Blikající světlo"
                MouseLeftButtonDown="HitSvetlo_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <!-- NÁSTĚNKA - vpravo -->
        <Button x:Name="HitNastenka"
                Width="280" Height="485"
                Canvas.Left="1350" Canvas.Top="160"
                Background="Transparent" Cursor="Hand"
                BorderThickness="0"
                ToolTip="Prozkoumat nástěnku"
                Click="HitNastenka_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <!-- NÁKRES OVERLAY - přes celý Canvas -->
        <Border x:Name="DrawingOverlay"
                Width="1672" Height="941"
                Canvas.Left="0" Canvas.Top="0"
                Visibility="Collapsed"
                Background="#DD000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="480">
                <Border BorderBrush="#2A2A2A" BorderThickness="1"
                        Background="#0A0A0A" Padding="30,22" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="┌──────────────────────┐"
                                   Foreground="#3A3A3A" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="│  [paní]    [muž]     │"
                                   Foreground="#777777" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,4"/>
                        <TextBlock Text="│       [holčička]     │"
                                   Foreground="#777777" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,4"/>
                        <TextBlock Text="│      [  ???  ]       │"
                                   Foreground="#993333" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,4"/>
                        <TextBlock Text="└──────────────────────┘"
                                   Foreground="#3A3A3A" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="Nákres výtahu. Jsou tam všichni... kromě tebe."
                           Foreground="#999999" FontFamily="Courier New" FontSize="13"
                           TextAlignment="Center" Margin="0,0,0,22"/>
                <Button Content="[ zavřít ]" HorizontalAlignment="Center"
                        Padding="16,8" FontFamily="Courier New"
                        Click="CloseDrawing_Click"/>
            </StackPanel>
        </Border>
    </Canvas>
</UserControl>