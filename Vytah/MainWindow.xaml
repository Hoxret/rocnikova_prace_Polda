<Window x:Class="Vytah.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VÝTAH"
        Height="941" Width="1672"
        MinHeight="941" MinWidth="1672"
        MaxHeight="941" MaxWidth="1672"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Black"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ContentControl x:Name="SceneHost" Grid.Row="0"/>

        <Border Grid.Row="1"
                Height="80"
                Background="#080808"
                BorderBrush="#1E1E1E" BorderThickness="0,1,0,0"
                Padding="14,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="KAPSY"
                           Foreground="#333333"
                           FontFamily="Courier New" FontSize="10"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <ItemsControl x:Name="InventoryItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="64" Height="64"
                                    Margin="0,0,8,0"
                                    Background="#101010"
                                    BorderBrush="#2A2A2A" BorderThickness="1"
                                    CornerRadius="2"
                                    ToolTip="{Binding Description}">
                                <Grid>
                                    <Image Source="{Binding IconPath}"
                                           Width="40" Height="40"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#888888"
                                               FontFamily="Courier New"
                                               FontSize="9"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,4"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl x:Name="EmptySlots">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                x:Name="DialogBorder"
                Background="#050505"
                BorderBrush="#1A1A1A" BorderThickness="0,1,0,0"
                Padding="22,14"
                MinHeight="100"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="SpeakerLabel"
                               Foreground="#555555"
                               FontFamily="Courier New" FontSize="11"
                               Margin="0,0,0,7"/>
                    <TextBlock x:Name="DialogLabel"
                               Foreground="#DEDEDE"
                               FontFamily="Courier New" FontSize="14"
                               TextWrapping="Wrap"
                               LineHeight="24"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="[ dál ]"
                           Foreground="#3A3A3A"
                           FontFamily="Courier New" FontSize="11"
                           VerticalAlignment="Bottom"
                           Margin="24,0,6,2"
                           Cursor="Hand"
                           MouseLeftButtonDown="ContinueDialog_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>