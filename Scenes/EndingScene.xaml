<UserControl x:Class="Vytah.Scenes.EndingScene"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Black">

        <Image x:Name="BgImage" Stretch="UniformToFill"/>

        <StackPanel VerticalAlignment="Bottom"
                    HorizontalAlignment="Left"
                    Margin="60,0,0,60">

            <TextBlock x:Name="EndingTitle"
                       FontFamily="Courier New" FontSize="18"
                       Foreground="#AAAAAA" TextAlignment="Left"
                       Margin="0,0,0,10" Opacity="0">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:2" BeginTime="0:0:1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <TextBlock x:Name="EndingSubtitle"
                       FontFamily="Courier New" FontSize="12"
                       Foreground="#666666" TextAlignment="Left"
                       TextWrapping="Wrap" MaxWidth="380"
                       Margin="0,0,0,24" Opacity="0">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:2" BeginTime="0:0:3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <Button x:Name="BtnMenu"
                    Content="[ zpět do menu ]"
                    Width="180" Height="40"
                    HorizontalAlignment="Left"
                    FontFamily="Courier New" FontSize="12"
                    Click="BtnMenu_Click" Opacity="0">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:1.5" BeginTime="0:0:5"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>