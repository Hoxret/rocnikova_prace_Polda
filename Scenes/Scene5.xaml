<UserControl x:Class="Vytah.Scenes.Scene5"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Image x:Name="BgImage" Source="pack://application:,,,/Assets/Backgrounds/scena5_vytah.png" Stretch="UniformToFill"/>

        <Rectangle x:Name="WhiteFade" Fill="#F8F8F8" Opacity="0"
                   IsHitTestVisible="False">
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="WhiteFade"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.8" Duration="0:0:2.5"
                                             BeginTime="0:0:0.5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>

        <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="100,0,0,120"
                Background="#AA000000" CornerRadius="3" Padding="10,6">
            <TextBlock Text="muž v obleku" Foreground="#999999"
                       FontFamily="Courier New" FontSize="12"/>
        </Border>

        <Border x:Name="ChoicePanel"
                Visibility="Collapsed"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,50">
            <StackPanel>
                <TextBlock Text="Co uděláš?"
                           Foreground="#777777" FontFamily="Courier New"
                           FontSize="12" HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="#1A0808" BorderBrush="#3A1818"
                            BorderThickness="1" CornerRadius="3"
                            Margin="0,0,16,0" Cursor="Hand" Padding="20,14"
                            MouseLeftButtonDown="BtnPustit_Click">
                        <StackPanel>
                            <TextBlock Text="[ pustit muže ven ]"
                                       Foreground="#BB4444"
                                       FontFamily="Courier New" FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="necháš ho odejít do bílé místnosti"
                                       Foreground="#552222" FontFamily="Courier New"
                                       FontSize="10" HorizontalAlignment="Center"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#08081A" BorderBrush="#18183A"
                            BorderThickness="1" CornerRadius="3"
                            Cursor="Hand" Padding="20,14"
                            MouseLeftButtonDown="BtnZavrit_Click">
                        <StackPanel>
                            <TextBlock Text="[ zavřít dveře ]"
                                       Foreground="#4477BB"
                                       FontFamily="Courier New" FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="stisknete tlačítko, výtah sjede dolů"
                                       Foreground="#223355" FontFamily="Courier New"
                                       FontSize="10" HorizontalAlignment="Center"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>