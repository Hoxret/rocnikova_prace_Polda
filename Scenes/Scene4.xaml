<UserControl x:Class="Vytah.Scenes.Scene4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Image x:Name="BgImage" Source="pack://application:,,,/Assets/Backgrounds/scena4_vytah.png" Stretch="UniformToFill"/>
        <Rectangle Fill="#44000000" IsHitTestVisible="False"/>

        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,140,80"
                Background="#AA000000" CornerRadius="3" Padding="10,6">
            <TextBlock Text="muž v obleku" Foreground="#999999"
                       FontFamily="Courier New" FontSize="12"/>
        </Border>

        <Border x:Name="PaniLabel"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="80,0,0,80"
                Background="#AA000000" CornerRadius="3" Padding="10,6"
                Visibility="Collapsed">
            <TextBlock Text="stará paní" Foreground="#999999"
                       FontFamily="Courier New" FontSize="12"/>
        </Border>

        <Border x:Name="HitPopel"
                Width="150" Height="90"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="-180,0,0,90"
                Background="Transparent" Cursor="Hand"
                ToolTip="Hromada popele"
                MouseLeftButtonDown="HitPopel_Click">
            <TextBlock Text="[ popel ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitAlarm"
                Width="70" Height="50"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="280,70,0,0"
                Background="Transparent" Cursor="Hand"
                ToolTip="Požární alarm"
                MouseLeftButtonDown="HitAlarm_Click">
            <TextBlock Text="[ alarm ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitRozvod"
                Width="100" Height="150"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Margin="20,0,0,0"
                Background="Transparent" Cursor="Hand"
                ToolTip="Rozvodná skříň"
                MouseLeftButtonDown="HitRozvod_Click">
            <TextBlock Text="[ rozvod ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="FusePuzzle"
                Visibility="Collapsed"
                Background="#EE000000">
            <Border Background="#0A0A0A" BorderBrush="#2A2A2A"
                    BorderThickness="1" CornerRadius="6"
                    Padding="36" Width="400"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="ROZVODNÁ SKŘÍŇ" Foreground="#444444"
                               FontFamily="Courier New" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Klikej na slot pro přepnutí barvy pojistky."
                               Foreground="#555555" FontFamily="Courier New"
                               FontSize="11" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Správné pořadí: červená → modrá → zelená"
                               Foreground="#333333" FontFamily="Courier New"
                               FontSize="10" HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="8,0">
                            <TextBlock Text="SLOT 1" Foreground="#333333"
                                       FontFamily="Courier New" FontSize="9"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Button x:Name="Slot1" Content="[ — ]"
                                    Width="90" Height="54" Tag="0"
                                    FontFamily="Courier New" FontSize="15"
                                    Click="SlotButton_Click"/>
                        </StackPanel>
                        <StackPanel Margin="8,0">
                            <TextBlock Text="SLOT 2" Foreground="#333333"
                                       FontFamily="Courier New" FontSize="9"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Button x:Name="Slot2" Content="[ — ]"
                                    Width="90" Height="54" Tag="1"
                                    FontFamily="Courier New" FontSize="15"
                                    Click="SlotButton_Click"/>
                        </StackPanel>
                        <StackPanel Margin="8,0">
                            <TextBlock Text="SLOT 3" Foreground="#333333"
                                       FontFamily="Courier New" FontSize="9"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Button x:Name="Slot3" Content="[ — ]"
                                    Width="90" Height="54" Tag="2"
                                    FontFamily="Courier New" FontSize="15"
                                    Click="SlotButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="PuzzleStatus" Text=""
                               Foreground="#AA3333" FontFamily="Courier New"
                               FontSize="11" HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                    <Button Content="[ zapojit ]" Margin="0,16,0,4"
                            Click="OdeslitPuzzle_Click"
                            Padding="16,8" FontFamily="Courier New"/>
                    <Button Content="zrušit" Margin="0,6,0,0"
                            Click="CancelPuzzle_Click"
                            Background="Transparent" Foreground="#444444"
                            BorderThickness="0" FontFamily="Courier New"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>