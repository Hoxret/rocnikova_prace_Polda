<UserControl x:Class="Vytah.Scenes.Scene1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Image x:Name="BgImage" Source="pack://application:,,,/Assets/Backgrounds/scena1_vytah.png" Stretch="UniformToFill"/>

        <StackPanel x:Name="PostavyPanel"
                    Orientation="Horizontal"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Left"
                    Margin="100,0,0,90"
                    Visibility="Collapsed">
            <Border Background="#AA000000" CornerRadius="3"
                    Padding="10,6" Margin="0,0,50,0">
                <TextBlock Text="stará paní"
                           Foreground="#AAAAAA"
                           FontFamily="Courier New" FontSize="12"/>
            </Border>
            <Border Background="#AA000000" CornerRadius="3" Padding="10,6">
                <TextBlock Text="muž v obleku"
                           Foreground="#AAAAAA"
                           FontFamily="Courier New" FontSize="12"/>
            </Border>
        </StackPanel>

        <Border x:Name="LiftPanel"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,0,30,0" Padding="16,20"
                Background="#0A0A0A" BorderBrush="#2A2A2A"
                BorderThickness="1" CornerRadius="4"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="VÝTAH" Foreground="#333333"
                           FontFamily="Courier New" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <Button Content="1"  Width="52" Height="52" Margin="0,3" Tag="1"  Click="FloorButton_Click" FontFamily="Courier New" FontSize="18"/>
                <Button Content="2"  Width="52" Height="52" Margin="0,3" Tag="2"  Click="FloorButton_Click" FontFamily="Courier New" FontSize="18"/>
                <Button Content="3"  Width="52" Height="52" Margin="0,3" Tag="3"  Click="FloorButton_Click" FontFamily="Courier New" FontSize="18"/>
                <Button Content="?"  Width="52" Height="52" Margin="0,3" Tag="?"  Click="FloorButton_Click" FontFamily="Courier New" FontSize="18" Foreground="#555555"/>
                <Button Content="?"  Width="52" Height="52" Margin="0,3" Tag="??" Click="FloorButton_Click" FontFamily="Courier New" FontSize="18" Foreground="#333333"/>
            </StackPanel>
        </Border>

        <Border x:Name="HitVytah"
                Width="200" Height="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,0"
                Background="Transparent"
                Cursor="Hand"
                ToolTip="Vstoupit do výtahu"
                MouseLeftButtonDown="HitVytah_Click"/>
    </Grid>
</UserControl>