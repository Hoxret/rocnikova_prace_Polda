<UserControl x:Class="Vytah.Scenes.MenuScene"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Grid>
		<Image x:Name="BgImage" Source="pack://application:,,,/Assets/Backgrounds/titulniscena_vytah.png" Stretch="UniformToFill"/>

		<!-- NOVÁ HRA TLAČÍTKO -->
		<Button x:Name="BtnNovaHra"
                Width="371"
                Height="80"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="136,0,0,328"
                Click="BtnNovaHra_Click"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"/>

		<!-- UKONČIT TLAČÍTKO -->
		<Button x:Name="BtnUkoncit"
                Width="371"
                Height="80"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="136,0,0,223"
                Click="BtnUkoncit_Click"
                BorderThickness="0"
                Cursor="Hand"
			    Content="Ukoncit" Background="Black"/>
	</Grid>
</UserControl>
