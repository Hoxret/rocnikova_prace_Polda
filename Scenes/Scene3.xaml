<UserControl x:Class="Vytah.Scenes.Scene3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Image x:Name="BgImage" Source="pack://application:,,,/Assets/Backgrounds/scena3_vytah.png" Stretch="UniformToFill"/>

        <!-- OBRAZ - vlevo -->
        <Border x:Name="HitObraz1"
                Width="260" Height="380"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="56,190,0,0"
                Background="White" Cursor="Hand"
                ToolTip="Prozkoumat obraz"
                MouseLeftButtonDown="HitObraz1_Click"/>

        <!-- TELEVIZE - vpravo -->
        <Border x:Name="HitTV"
                Width="340" Height="280"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,240,20,0"
                Background="Black" Cursor="Hand"
                ToolTip="Televize"
                MouseLeftButtonDown="HitTV_Click"/>

        <!-- KOMODA pod televizí -->
        <Border x:Name="HitKomoda"
                Width="510" Height="263"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,40"
                Background="Yellow" Cursor="Hand"
                ToolTip="Prozkoumat komodu"
                MouseLeftButtonDown="HitKomoda_Click"/>

        <!-- MUŽ V OBLEKU - klikatelný -->
        <Border x:Name="HitMuz"
                Width="312" Height="243"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,698,0,0"
                Background="DarkBlue" Cursor="Hand"
                ToolTip="Promluvit s mužem"
                MouseLeftButtonDown="HitMuz_Click"/>

        <!-- DVEŘE VÝTAHU - skryté, ukážou se po rozluštění kódu -->
        <Border x:Name="HitDvere"
                Width="200" Height="500"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="Transparent" Cursor="Hand"
                Visibility="Collapsed"
                ToolTip="Dveře výtahu"
                MouseLeftButtonDown="HitDvere_Click">
            <Border BorderBrush="#44FFFF00" BorderThickness="1" CornerRadius="2"/>
        </Border>

        <!-- KEYPAD OVERLAY -->
        <Border x:Name="KeypadOverlay"
                Visibility="Collapsed"
                Background="#DD000000">
            <Border Background="#0A0A0A" BorderBrush="#2A2A2A"
                    BorderThickness="1" CornerRadius="6"
                    Padding="36" Width="300"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="PŘÍSTUPOVÝ KÓD" Foreground="#444444"
                               FontFamily="Courier New" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBox x:Name="CodeInput"
                             FontFamily="Courier New" FontSize="26"
                             TextAlignment="Center" MaxLength="4"
                             HorizontalAlignment="Stretch" Padding="8"/>
                    <Button Content="[ potvrdit ]" Margin="0,14,0,0"
                            Click="ConfirmCode_Click"
                            Padding="14,8" FontFamily="Courier New"/>
                    <Button Content="zrušit" Margin="0,8,0,0"
                            Click="CancelCode_Click"
                            Background="Transparent" Foreground="#444444"
                            BorderThickness="0" FontFamily="Courier New"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>