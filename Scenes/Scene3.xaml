<UserControl x:Class="Vytah.Scenes.Scene3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Image x:Name="BgImage" Source="pack://application:,,,/Assets/Backgrounds/scena3_vytah.png" Stretch="UniformToFill"/>

        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,150,85"
                Background="#AA000000" CornerRadius="3" Padding="10,6">
            <TextBlock Text="muž v obleku"
                       Foreground="#AAAAAA" FontFamily="Courier New" FontSize="12"/>
        </Border>

        <Border x:Name="HitObraz1"
                Width="90" Height="110"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="70,90,0,0"
                Background="Transparent" Cursor="Hand"
                ToolTip="Prozkoumat obraz"
                MouseLeftButtonDown="HitObraz1_Click">
            <TextBlock Text="[ obraz ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitObraz2"
                Width="90" Height="110"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="200,110,0,0"
                Background="Transparent" Cursor="Hand"
                ToolTip="Prozkoumat obraz"
                MouseLeftButtonDown="HitObraz2_Click">
            <TextBlock Text="[ obraz ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitTV"
                Width="220" Height="140"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,160"
                Background="Transparent" Cursor="Hand"
                ToolTip="Televize"
                MouseLeftButtonDown="HitTV_Click">
            <TextBlock Text="[ televize ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitDvere"
                Width="130" Height="210"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,50,70"
                Background="Transparent" Cursor="Hand"
                Visibility="Collapsed"
                ToolTip="Uzamčené dveře"
                MouseLeftButtonDown="HitDvere_Click">
            <Border BorderBrush="#44FFFF00" BorderThickness="1" CornerRadius="2">
                <TextBlock Text="[ dveře — kód? ]" Foreground="#55FFFF00"
                           FontFamily="Courier New" FontSize="10"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>

        <Border x:Name="KeypadOverlay"
                Visibility="Collapsed"
                Background="#DD000000">
            <Border Background="#0A0A0A" BorderBrush="#2A2A2A"
                    BorderThickness="1" CornerRadius="6"
                    Padding="36" Width="300"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="PŘÍSTUPOVÝ KÓD" Foreground="#444444"
                               FontFamily="Courier New" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBox x:Name="CodeInput"
                             FontFamily="Courier New" FontSize="26"
                             TextAlignment="Center" MaxLength="4"
                             HorizontalAlignment="Stretch" Padding="8"/>
                    <Button Content="[ potvrdit ]" Margin="0,14,0,0"
                            Click="ConfirmCode_Click"
                            Padding="14,8" FontFamily="Courier New"/>
                    <Button Content="zrušit" Margin="0,8,0,0"
                            Click="CancelCode_Click"
                            Background="Transparent" Foreground="#444444"
                            BorderThickness="0" FontFamily="Courier New"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>