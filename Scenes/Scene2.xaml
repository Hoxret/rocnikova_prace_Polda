<UserControl x:Class="Vytah.Scenes.Scene2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Image x:Name="BgImage" Source="pack://application:,,,/Assets/Backgrounds/scena2_vytah.png" Stretch="UniformToFill"/>

        <Border x:Name="HitNastenka"
                Width="130" Height="90"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="90,140,0,0"
                Background="Transparent" Cursor="Hand"
                ToolTip="Prozkoumat nástěnku"
                MouseLeftButtonDown="HitNastenka_Click">
            <TextBlock Text="[ nástěnka ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitSchranky"
                Width="140" Height="110"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="40,0,0,110"
                Background="Transparent" Cursor="Hand"
                ToolTip="Prozkoumat schránky"
                MouseLeftButtonDown="HitSchranky_Click">
            <TextBlock Text="[ schránky ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitSvetlo"
                Width="80" Height="40"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,20,0,0"
                Background="Transparent" Cursor="Hand"
                ToolTip="Blikající světlo"
                MouseLeftButtonDown="HitSvetlo_Click">
            <TextBlock Text="[ světlo ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitKolo"
                Width="100" Height="90"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,60,100"
                Background="Transparent" Cursor="Hand"
                ToolTip="Dětské kolo"
                MouseLeftButtonDown="HitKolo_Click">
            <TextBlock Text="[ kolo ]" Foreground="#22FFFFFF"
                       FontFamily="Courier New" FontSize="10"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Border>

        <Border x:Name="HitRozvod"
                Width="90" Height="130"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,0,20,0"
                Background="Transparent" Cursor="Hand"
                Visibility="Collapsed"
                ToolTip="Rozvodná skříň — zapojit pojistku"
                MouseLeftButtonDown="HitRozvod_Click">
            <Border BorderBrush="#44FFFF00" BorderThickness="1" CornerRadius="2">
                <TextBlock Text="[ rozvod ]" Foreground="#55FFFF00"
                           FontFamily="Courier New" FontSize="10"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Border>

        <Border x:Name="DrawingOverlay"
                Visibility="Collapsed"
                Background="#DD000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="480">
                <Border BorderBrush="#2A2A2A" BorderThickness="1"
                        Background="#0A0A0A" Padding="30,22" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="┌──────────────────────┐"
                                   Foreground="#3A3A3A" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="│  [paní]    [muž]     │"
                                   Foreground="#777777" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,4"/>
                        <TextBlock Text="│       [holčička]     │"
                                   Foreground="#777777" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,4"/>
                        <TextBlock Text="│      [  ???  ]       │"
                                   Foreground="#993333" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,4"/>
                        <TextBlock Text="└──────────────────────┘"
                                   Foreground="#3A3A3A" FontFamily="Courier New"
                                   FontSize="13" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="Nákres výtahu. Jsou tam všichni... kromě tebe."
                           Foreground="#999999" FontFamily="Courier New" FontSize="13"
                           TextAlignment="Center" Margin="0,0,0,22"/>
                <Button Content="[ zavřít ]" HorizontalAlignment="Center"
                        Padding="16,8" FontFamily="Courier New"
                        Click="CloseDrawing_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>